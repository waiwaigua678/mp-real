# Source this file after replacing the paths for the robot controller:
#   source configs/rm2.env
#
# RM_SDK_ROOT is enough when the vendor layout contains both files below.
export RM_SDK_ROOT=/opt/motrix/rm2-sdk

# Use these instead when config.ini and the shared library live separately.
# export RM_CONFIG=/opt/motrix/rm2-sdk/build/config.ini
# export RM_SDK_LIB=/opt/motrix/rm2-sdk/Robotic_Arm/lib/libapi_cpp.so
